<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Results Management System' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
<% if (typeof currentUser !== 'undefined' && currentUser) { %>
<nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4 no-print">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/<%= currentUser.role %>">
      <%= school ? school.name : 'Results System' %>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav me-auto">
        <% if (currentUser.role === 'admin') { %>
          <li class="nav-item"><a class="nav-link" href="/admin">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/students">Students</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/classes">Classes</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/subjects">Subjects</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/teachers">Teachers</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/results">Results</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/config">School Configuration</a></li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/teacher">My Assignments</a></li>
        <% } %>
      </ul>
      <span class="navbar-text text-white me-3">
        <%= currentUser.name %> (<%= currentUser.role %>) &middot; School code: <%= school ? school.code : '' %>
      </span>
      <a href="/logout" class="btn btn-outline-light btn-sm">Log out</a>
    </div>
  </div>
</nav>
<% } %>
<div class="container pb-5">
  <% if (typeof success !== 'undefined' && success && success.length) { %>
    <% success.forEach(function(msg) { %>
      <div class="alert alert-success no-print"><%= msg %></div>
    <% }) %>
  <% } %>
  <% if (typeof error !== 'undefined' && error && error.length) { %>
    <% error.forEach(function(msg) { %>
      <div class="alert alert-danger no-print"><%= msg %></div>
    <% }) %>
  <% } %>
</div>
