<%- include('../partials/header', { title: 'Psychomotor Skills' }) %>

<h3 class="mb-1">Psychomotor Skills — <%= cls.name %></h3>
<p class="text-muted mb-4"><%= school.session %> &middot; <%= school.term %></p>

<div class="card p-3 mb-3">
  <div class="d-flex gap-3 flex-wrap">
    <% for (let r = 5; r >= 1; r--) { %>
      <span><strong><%= r %></strong> = <%= rating[r] %></span>
    <% } %>
  </div>
</div>

<form method="POST" action="/formteacher/psychomotor">
  <div class="card p-3">
    <div class="table-responsive">
      <table class="table align-middle table-sm">
        <thead>
          <tr>
            <th style="min-width:160px;">Student</th>
            <% skills.forEach(function(sk) { %><th style="min-width:90px;" class="text-center"><%= sk.label %></th><% }) %>
            <th style="min-width:160px;">Comment</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(function(st) { %>
            <% const ex = existingMap[st.id] || {}; %>
            <tr>
              <td>
                <%= st.name %>
                <input type="hidden" name="studentIds" value="<%= st.id %>">
              </td>
              <% skills.forEach(function(sk) { %>
                <td class="text-center">
                  <select name="<%= sk.key %>" class="form-select form-select-sm">
                    <option value="">-</option>
                    <% for (let r = 5; r >= 1; r--) { %>
                      <option value="<%= r %>" <%= (ex[sk.key === 'musical_ability' ? 'musicalAbility' : sk.key === 'practical_skills' ? 'practicalSkills' : sk.key === 'verbal_fluency' ? 'verbalFluency' : sk.key] == r) ? 'selected' : '' %>><%= r %></option>
                    <% } %>
                  </select>
                </td>
              <% }) %>
              <td>
                <input type="text" name="form_teacher_comment" class="form-control form-control-sm"
                  value="<%= ex.formTeacherComment || '' %>" placeholder="Optional comment">
              </td>
            </tr>
          <% }) %>
          <% if (!students.length) { %>
            <tr><td colspan="<%= skills.length + 2 %>" class="text-muted text-center">No students in this class yet.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <% if (students.length) { %>
    <button type="submit" class="btn btn-primary mt-3">Save Psychomotor Scores</button>
  <% } %>
</form>

<%- include('../partials/footer') %>
