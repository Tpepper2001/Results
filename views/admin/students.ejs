<%- include('../partials/header', { title: 'Students' }) %>

<h3 class="mb-4">Register Students</h3>

<div class="card p-4 mb-4">
  <form method="POST" action="/admin/students" class="row g-2">
    <div class="col-md-4">
      <label class="form-label">Full Name *</label>
      <input type="text" name="name" class="form-control" required>
    </div>
    <div class="col-md-2">
      <label class="form-label">Reg. No.</label>
      <input type="text" name="regNo" class="form-control" placeholder="Auto if blank">
    </div>
    <div class="col-md-2">
      <label class="form-label">Class *</label>
      <select name="classId" class="form-select" required>
        <option value="">Select</option>
        <% classes.forEach(function(c) { %>
          <option value="<%= c.id %>"><%= c.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-2">
      <label class="form-label">Gender</label>
      <select name="gender" class="form-select">
        <option value="">-</option>
        <option>Male</option>
        <option>Female</option>
      </select>
    </div>
    <div class="col-md-2">
      <label class="form-label">Date of Birth</label>
      <input type="date" name="dob" class="form-control">
    </div>
    <div class="col-12">
      <button type="submit" class="btn btn-primary mt-2">Register Student</button>
    </div>
  </form>
  <% if (!classes.length) { %>
    <p class="text-danger mt-2 mb-0">You need to <a href="/admin/classes">add a class</a> before registering students.</p>
  <% } %>
</div>

<div class="card p-4">
  <table class="table">
    <thead><tr><th>Name</th><th>Reg. No.</th><th>Class</th><th>Gender</th><th></th></tr></thead>
    <tbody>
      <% students.forEach(function(s) { %>
        <tr>
          <td><%= s.name %></td>
          <td><%= s.regNo %></td>
          <td><%= classMap[s.classId] || '-' %></td>
          <td><%= s.gender %></td>
          <td class="text-end">
            <a href="/results/<%= s.id %>" class="btn btn-sm btn-outline-primary">View Result</a>
            <form method="POST" action="/admin/students/<%= s.id %>/delete" class="d-inline" onsubmit="return confirm('Remove this student?');">
              <button class="btn btn-sm btn-outline-danger">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (!students.length) { %>
        <tr><td colspan="5" class="text-muted text-center">No students registered yet.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
