PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string

# From your Supabase project: Project Settings > API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use the "service_role" SECRET key (NOT the "anon" public key).
# This key bypasses Row Level Security and must never be exposed to the browser
# or committed to version control — it's only read here, server-side.
SUPABASE_SERVICE_KEY=your-service-role-secret-key
